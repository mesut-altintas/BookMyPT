rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Yardımcı fonksiyonlar
    function isLoggedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isPT() {
      return isLoggedIn() && getUserData().role == 'pt';
    }

    function isMember() {
      return isLoggedIn() && getUserData().role == 'member';
    }

    function getTrainerIdOfMember() {
      return getUserData().trainerId;
    }

    // /users/{userId}
    match /users/{userId} {
      allow read: if isLoggedIn() && isOwner(userId);
      allow create: if isLoggedIn() && isOwner(userId);
      allow update: if isLoggedIn() && isOwner(userId);
    }

    // /trainers/{trainerId}
    match /trainers/{trainerId} {
      // PT kendi trainer dokümanını okuyup yazabilir
      allow read, write: if isPT() && isOwner(trainerId);
      // Üye, bağlı olduğu PT'nin trainer verisini okuyabilir
      allow read: if isMember() && getTrainerIdOfMember() == trainerId;
    }

    // /members/{memberId}
    match /members/{memberId} {
      // PT, kendi üyelerini yönetebilir
      allow read, write: if isPT() &&
        get(/databases/$(database)/documents/members/$(memberId)).data.trainerId ==
        request.auth.uid;
      // Üye kendi verisini okuyabilir
      allow read: if isMember() &&
        get(/databases/$(database)/documents/members/$(memberId)).data.userId ==
        request.auth.uid;
    }

    // /bookings/{bookingId}
    match /bookings/{bookingId} {
      // PT kendi takvimindeki bookingleri yönetebilir
      allow read, write: if isPT() &&
        resource.data.trainerId == request.auth.uid;
      // Üye, bağlı olduğu PT'nin bookinglerini okuyabilir ve kendi adına oluşturabilir
      allow read: if isMember() &&
        resource.data.trainerId == getTrainerIdOfMember();
      allow create: if isMember() &&
        request.resource.data.trainerId == getTrainerIdOfMember() &&
        request.resource.data.status == 'confirmed';
      // Üye sadece kendi bookingini pending_cancel yapabilir
      allow update: if isMember() &&
        resource.data.memberId == getUserData().memberId &&
        request.resource.data.status == 'pending_cancel';
    }

    // /calendarBlocks/{blockId}
    match /calendarBlocks/{blockId} {
      // PT kendi bloklarını yönetebilir
      allow read, write: if isPT() &&
        resource.data.trainerId == request.auth.uid;
      // Üye, bağlı PT'nin bloklarını okuyabilir
      allow read: if isMember() &&
        resource.data.trainerId == getTrainerIdOfMember();
    }
  }
}
